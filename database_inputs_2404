# import the relevant library
import sqlite3


# connect to the database
DB = sqlite3.connect("predicted_inputs.db")

# create a cursor to send SQL commands to the database
cursor = DB.cursor()

# create the input table, Quelle für 'INTEGER PRIMARY KEY AUTOINCREMENT': CODEX
cursor.execute(
    """
    CREATE TABLE IF NOT EXISTS input (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        age TEXT,
        studien TEXT,
        schlaf INTEGER
        lernzeit INTEGER,
        stress TEXT,
        bild INTEGER,
        gesund TEXT,
        hilfe INTEGER,
        pausen INTEGER,
        fail INTEGER,
        freetime INTEGER,
        goout TEXT,
        pendel INTEGER,
        food TEXT,
        sport INTEGER
    )
    """
)


def add_input(name, age, studien, schlaf, lernzeit, stress, bild, gesund, hilfe, pausen, fail, freetime, goout, pendel, food, sport):
    cursor.execute(
        """
        INSERT INTO input (
            name,
            age, 
            studien,
            schlaf,
            lernzeit,
            stress,
            bild,
            gesund,
            hilfe,
            pausen,
            fail,
            freetime,
            goout,
            pendel,
            food,
            sport
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (name, age, studien, schlaf, lernzeit, stress, bild, gesund, hilfe, pausen, fail, freetime, goout, pendel, food, sport),
    )

    DB.commit()


def get_inputs():
    """Get all rows from the input table."""
    cursor.execute(
        """
        SELECT *
        FROM input
        """
    )

    return cursor.fetchall()
