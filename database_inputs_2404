def add_input(name, lernzeit, bild, gesund, hilfe, pausen, fail, freetime, goout, pendel, food, sport):
    cursor.execute(
        """
        INSERT INTO input (
            name,
            lernzeit,
            bild,
            gesund,
            hilfe,
            pausen,
            fail,
            freetime,
            goout,
            pendel,
            food,
            sport
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (name, lernzeit, bild, gesund, hilfe, pausen, fail, freetime, goout, pendel, food, sport),
    )

    DB.commit()


def get_inputs():
    """Get all rows from the input table."""
    cursor.execute(
        """
        SELECT *
        FROM input
        """
    )

    return cursor.fetchall()
