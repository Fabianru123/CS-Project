#code Claire: Variablen, Berechnung des Scores und Darstellung als Spiderweb und als Passprobability 

from databases_sql import add_input #added by Helena

import streamlit as st



#code sidebar 

with st.sidebar:
    st.write("Score")

    st.subheader("Deine persönlichen Angaben")

    name = st.text_input("Name")                            #modified by H.
    age = st.number_input("Alter", 0, None, None, 1)        #modified by H.
    studien = st.text_input("Studiengang")

 #code title and welcoming page    

st.title("PredictEd")

st.divider()

st.header("Berechnung des Scores")

st.divider ()

#code persönliche angaben 

                  #modified by H.

#code variablen and sliders 

st.subheader("Deine Variablen")
st.caption("Alle Fragen sind mit Durchschnitten über eine längere Periode zu beantworten")


if "punkte" not in st.session_state:
    st.session_state.punkte = 0


pschlaf = 0
schlaf = st.slider("Schlaf *(in Stunden pro Nacht)*",0, 10)


plernzeit = 0
lernzeit = st.slider("Lernzeit *(in Stunden pro Woche)*", 0, 50)


pstress1 = 0
stress = st.selectbox ("Akademischer Stress", ("Wählen", "Tief", "Mittel", "Hoch"))


pbild = 0
bild = st.slider("Bildschirmzeit *(in Stunden pro Tag)*", 0, 24)


pgesund = 0
gesund = st.selectbox("Gesundheitszustand", ("Wählen", "Sehr gut", "Gut", "Schlecht"))


philfe= 0
hilfe = st.slider("Nachhilfe *(in Stunden pro Woche)*", 0, 20)


ppausen = 0
pausen = st.slider("Pausen *(in Prozent der Lernzeit)*", 0, 100)


pfail = 0
fail = st.slider("Anzahl nicht bestandener Fächer", 0, 10)


pfreetime = 0
freetime = st.slider("Freizeit und Aktivitäten *(in Stunden pro Woche)*", 0, 50)


pgoout= 0
goout = st.selectbox("Wie fühlst du dich nach dem Ausgang", ("Wählen", "Lernen ist gut möglich", "Lernen ist schwierig", "Lernen ist unmöglich", "Ich gehe nicht in Ausgang"))


ppendel = 0
pendel = st.slider("Pendelzeit zwischen der Uni und der Wohnung *(in Stunden pro Tag)*", 0, 6)


pfood = 0
food = st.selectbox("Ernähung", ("Wählen", "Sehr gesund", "Kommt drauf an", "Überhaupt nicht gesund"))


psport = 0
sport = st.slider("Sport *(in Stunden pro Woche)*", 0, 40)


if st.button("Bestätigen", key = "button"):
    if schlaf >= 8:
       pschlaf = 4
    elif schlaf > 6 and schlaf < 8:
        pschlaf = 2
    else:
       pschlaf = 1
    
    if lernzeit >= 21:
        plernzeit = 4
    elif 11 <= lernzeit <= 20:
        plernzeit = 2
    else:
        plernzeit = 1

    if stress == "Tief":
        pstress1 = 4
    elif stress == "Mittel":
        pstress1 = 2
    else: 
        pstress1 = 1    

    if 0 <= bild <= 1:
        pbild = 4
    elif 1 < bild:
        pbild = 2
    else:
        pbild = 1   

    if gesund == "Sehr gut":
        pgesund = 4
    elif gesund == "Gut":
        pgesund = 2 
    else:
        pgesund = 1                      

    if hilfe >= 2:
        philfe = 4
    elif 1 <= hilfe < 2:
        philfe = 2
    else:
        philfe = 1

    if 15 <= pausen <= 25:
        ppausen = 4
    elif 25 < pausen <= 40:
        ppausen = 2
    else: 
        ppausen = 1


    if fail == 0:
        pfail = 2
    elif 1 <= fail <= 2:
        pfail = 1
    else:
        pfail = 0.5     

    if 12 >= freetime >= 8:
        pfreetime = 2
    elif 12 < freetime <= 20:
        pfreetime = 1
    else:
        pfreetime = 0.5    

    if goout == "Lernen ist gut möglich":
        pgoout = 2
    elif goout == "Ich gehe nicht in Ausgang":
        pgoout = 2
    elif goout == "Lernen ist schwierig":
        pgoout = 1 
    else:
        pgoout = 0.5                                  

    if 0 <= pendel <= 1:
        ppendel = 2
    elif 1 < pendel <= 3:
        ppendel = 1
    else:
        pgoout = 0.5    

    if food == "Sehr gesund":
        pfood = 2
    elif food == "Kommt drauf an":
        pfood = 1
    else:
        pfood = 0.5    

    if 6 <= sport <= 10 :
        psport = 2
    elif 3 <= sport <= 5:
        psport = 1
    else:
        psport = 0.5    

    add_input(name, age, studien, schlaf, lernzeit, stress, bild, gesund, hilfe, pausen, fail, freetime, goout, pendel, food, sport)


st.session_state.punkte = pschlaf + plernzeit + pstress1 + pbild + pgesund + philfe + ppausen + pfail + pfreetime + pgoout + ppendel + pfood + psport 



st.write("Punkte =", st.session_state.punkte)

st.divider ()


st.subheader("Dein Score")     

score = 2.5 * st.session_state.punkte 
# 2.5 = 100 / 40 = Score / Anzhal max Punkte nach der aktuellen Variablen 
# 100 = max Score und entspricht der maximalen Wahrscheinlichkeit 

st.write(score)

with st.sidebar: 
    st.write("Dein Score:", score)

col1, col2 = st.columns(2) 


#Quelle: ChatGPT für die Struktur 

#spiderweb

with col1: 

    import plotly.graph_objects as go

    categories = ['Schlaf', 'Lernzeit', 'Stress', 'Bildschirmzeit', 'Gesundheitszustand', 'Nachhilfe', "Pausen",
                "Nicht bestandener Fächer", "Freizeit", "Alkohol", "Pendelzeit", "Ernähung", "Sport"]
    values = [pschlaf, plernzeit, pstress1, pbild, pgesund, philfe, ppausen, 2*pfail, 2*pfreetime, 2*pgoout,  2*ppendel, 2*pfood, 2*psport]

    fig_radar = go.Figure()
    fig_radar.add_trace(go.Scatterpolar(
        r=values,
        theta=categories,
        fill='toself',
        fillcolor="rgba(255, 75, 75, 0.4)",   
        line=dict(color="rgb(255, 75, 75)")))

    fig_radar.update_layout(
        polar=dict(
            radialaxis=dict(
                visible=True, 
                range=[0,4])),
        showlegend=False)

    st.plotly_chart(fig_radar)


#score darstellung 
#Quelle ChatGPT für die Struktur 

with col2: 

    import plotly.graph_objects as go

    pass_probability = score 

    if 0 <= pass_probability <= 34:
        color = "red"
    elif 35 <= pass_probability <= 70:
        color = "yellow"
    else: 
        color = "green"

    fig_gauge = go.Figure(go.Indicator(
        mode="gauge+number",
        value=pass_probability,
        number={'suffix': "%"},
        gauge={'axis': {'range': [0,100]},
            'bar': {"color": color},
            'bgcolor': "lightgray"}))

    st.plotly_chart(fig_gauge)

 #tipps 

st.subheader("Deine personalisierten Tipps")

if pschlaf == 4:
    st.write ("Du ruhst dich optimal aus. Nutze deine Energie am Vormittag, direkt für anspruchsvolle Aufgaben, solange deine Konzentration hoch ist")
elif pschlaf == 2:
    st.write("Versuche heute Abend schon 30 Minuten früher ins Bett zu gehen und auf Bildschirmzeit  zu verzichten, damit sich dein Körper optimal erholen kann")
elif pschlaf == 1:
    st.write ("Gönne deinem Körper heute die nötige Erholung. Versuche, dich mit einem 15-minütigen Powernap zu erholen und gehe deutlich früher Schlafen, um dein Schlafdefizit abzubauen")

if plernzeit == 4:
    st.write("Weiter so! Nutze deine Lernzeit möglichst effizient, indem du sie gezielt einsetzt, damit du deine Energie optimal nutzen kannst")
elif plernzeit == 2:
    st.write("Mit nur 30 Minuten zusätzlicher Lernzeit und einem klaren Fokus, kannst du deine Lernziele künftig effizienter und entspannter erreichen.")
elif plernzeit == 1:
    st.write("Beginne heute mit einer kleinen, aber fokussierten Lerneinheit in einer ruhigen Umgebung. So findest du wieder zu deinem Lernrhythmus und kommst deinen Lernzielen einen grossen Schritt näher")

if pstress1 == 4:
    st.write ("Du scheinst alles im Griff zu haben, nutze deine Ruhe um bei einem schwierigen Thema voranzukommen")
elif pstress1 == 2: 
    st.write ("Du fühlst dich etwas überwältigt, priorisiere heute nur die drei wichtigsten Aufgaben und lass dir von uns ein Lernplan erstellen")
elif pstress1 == 1:
    st.write("Du fühlst dich überbelastet, streiche unnötige To-dos und fokussiere dich auf die wichtigsten Lernziele")

if pbild == 4: 
    st.write ("Behalte die niedrige Bildschirmzeit, sie hilft dir komplexe Lerninhalte schneller zu verarbeiten")
elif  pbild == 2:
    st.write("Du hast eine erhöhte Bildschirmzeit,  versuche deshalb 30min vor dem Schlafen und in deinen Lenrpausen bewusst auf dein Handy zu verzichten")
elif pbild == 1:
    st.write ("Du benötigst ein digital Detox, schalte beim Lernen alle Benachtitigungen aus und lege dein Handy ausser Sichtweite")

if philfe == 4:
    st.write("Du hast ein solides Verständnis, festige dein Wissen indem du deinen Mitstudenten den Inhalt erklärst oder Altklausuren löst")
elif philfe == 2:
    st.write("Fülle wenn möglich Altklausuren aus, und prüfe welche Lücken du selber schliessen kannst und für welche Themen du Nachhilfe benötigst") 
elif philfe == 1:
    st.write("Wenn du das Gefühl hast, dass du bestimmte Themen nicht selbst erarbeiten kannst, hole dir rechtzeitig Hilfe in einem Tutorium oder von einer Nachhilfelehrkraft")

if ppausen == 4:
    st.write("Du hast das optimale Balance zwischen  Lernen und Pausen. Nutze deine Pausen  um an die frische Luft zu gehen und neue Energie zu tanken")
elif ppausen == 2:
    st.write("Du arbeitest zu lange am Stück, probiere die Pomodero-Technik aus ( 25min lernen und 5min Pause)")   
elif ppausen == 1:
    st.write ("Pausen sind esentiell für dein Gehirn, gönne dir heute noch eine  30-60min handyfreie Pause.")

if pfail == 2: 
    st.write("Deine Lernstrategie scheint gut zu funktionieren und lass dir einen Lernplan von uns erstellen um dich möglichst effizient vorzubereiten")
elif pfail == 1: 
    st.write ("Analysiere deine Fehlerquelle, suche dir rechtzeitig eine Lerngruppe  und tausche dich mit anderen aus")
elif pfail == 1:
    st.write ("Hole dir Hilfe von der Studienberatung oder einem Mentor um das Semster erfolgreich abzuschliessen")  

if pfreetime == 2:
    st.write ("Du hast eine gute Balance zwischen deinem Uni und deinem Privatleben. Das erhöht deine kognitive Leistungsfähigkeit. Weiter so!")
elif pfreetime == 1:
    st.write ("Gönne dir etwas Abwechslung vom lernen, plane dieses Wochenende bewusst eine Aktivität ein die nichts mit der Uni zu tun hat.")
elif pfreetime == 0.5:
    st.write("Es fehlt dir an der nötigen Balance zwischen Uni und Privatleben. Triff dich in den nächsten Tagen mit Freunden oder nimm dir heute Abend etwas Zeit für dich")    

if ppendel == 2: 
    st.write("Du hast Glück mit deinem kurzen Fahrtweg, dies gibt dir mehr Zeit für Schlaf oder Freizeitaktivitäten.")
elif ppendel == 1:
    st.write ("Nutze die Fahrt um mit Karteikarten zu lernen oder für ein kurzes Quiz.") 
elif ppendel == 0.5: 
    st.write ("Du hast einen langen Fahrtweg, lass dich von dem nicht stressen. Nutze die Zeit bewusst für ein Quiz oder ein fachbezogenes Hörbuch")                       

if pfood == 2:
    st.write("Du ernährst dich ideal.Behalte deine Routine bei und achte auch eine ausreichende Hydrierung.")
elif pfood == 1:
    st.write("Eine gesunde Ernährung wirkt sich auf deinen Lernerfolg aus nutze Brainfood wie Nüsse oder Obst zwischen in den Lernpausen")
elif pfood == 0.5:
    st.write ("Ohne eine ausgewogene Ernährung, hat dein Körper nicht die benötigte Energie, iss 3 feste Mahlzeiten mit Früchten/Gemüse")

if psport == 2:
    st.write ("Behalte die regelmässige Bewegung bei, sie fördert deine Durchblutung und hilft dir die Lerninhalte optimal aufzunehmen und konzentriert zu bleiben.")
elif psport == 1:
    st.write ("Mit Hilfe eines kurzen Spaziergangs oder einem 15-Minütigen Workout kannst du deine Konzentration weiter steigern und noch effizienter lernen.")
elif psport == 0.5:
    st.write ("Regelmässige Bewegung ist ein wichtiger Faktor für deinen Lernerfolg. Sie hilft dir, konzentriert zu bleiben. Versuche es heute mit einem 30-minütigen Spaziergang oder einem Workout")        
