        progress_html += f'<div class="step-dot {cls}" style="flex:1;width:auto;height:4px;border-radius:2px;"></div>'
    progress_html += '</div>'
    st.markdown(progress_html, unsafe_allow_html=True)
    st.markdown(f'<div style="font-size:12px;color:#888;font-family:\'DM Mono\',monospace;margin-bottom:16px;">FRAGE {step} VON {total}</div>', unsafe_allow_html=True)

    with st.container():
        if step == 1:
            st.markdown("**Wie viele Stunden hast du diese Woche gelernt?**")
            val = st.slider("Lernstunden", 0, 40,
                            st.session_state.checkin_answers.get("studytime", 5),
                            label_visibility="collapsed")
            st.session_state.checkin_answers["studytime"] = val
            st.markdown(f'<div style="font-size:32px;font-weight:700;text-align:center;font-family:\'DM Mono\',monospace;color:#1a1a1a;">{val}h</div>', unsafe_allow_html=True)

        elif step == 2:
            st.markdown("**Wie viele Stunden hast du diese Woche verschlafen?**")
            options = ["0", "1–2", "3–5", "6–10", "> 10"]
            sel = st.radio("Fehlstunden", options, horizontal=True,
                           index=options.index(st.session_state.checkin_answers.get("absences", "0")),
                           label_visibility="collapsed")
            st.session_state.checkin_answers["absences"] = sel

        elif step == 3:
            st.markdown("**Wie lange hast du diese Woche durchschnittlich geschlafen?**")
            options = ["< 5h", "5–6h", "7–8h", "> 8h"]
            sel = st.radio("Schlafdauer", options, horizontal=True,
                           index=options.index(st.session_state.checkin_answers.get("sleep", "7–8h")),
                           label_visibility="collapsed")
            st.session_state.checkin_answers["sleep"] = sel

        elif step == 4:
            st.markdown("**Wie motiviert fühlst du dich aktuell für das Studium?**")
            options = ["😞 Sehr wenig", "😕 Eher wenig", "😐 Mittel", "🙂 Gut", "😄 Sehr gut"]
            sel = st.radio("Motivation", options, horizontal=True,
                           index=options.index(st.session_state.checkin_answers.get("motivation", "😐 Mittel")),
                           label_visibility="collapsed")
            st.session_state.checkin_answers["motivation"] = sel

    # Navigation
    col_back, col_next = st.columns([1, 4])
    with col_back:
        if step > 1:
            if st.button("← Zurück"):
                st.session_state.checkin_step -= 1
                st.rerun()
    with col_next:
        label = "Score berechnen →" if step == total else "Weiter →"
        if st.button(label):
            if step < total:
                st.session_state.checkin_step += 1
                st.rerun()
            else:
                # Compute new score
                answers = st.session_state.checkin_answers
                study_h = answers.get("studytime", 5)
                abs_map = {"0": 0, "1–2": 1.5, "3–5": 4, "6–10": 8, "> 10": 12}
                sleep_map = {"< 5h": 4.5, "5–6h": 5.5, "7–8h": 7.5, "> 8h": 8.5}
                motiv_map = {"😞 Sehr wenig": 1, "😕 Eher wenig": 2, "😐 Mittel": 3, "🙂 Gut": 4, "😄 Sehr gut": 5}

                abs_h   = abs_map.get(answers.get("absences", "0"), 0)
                sleep_h = sleep_map.get(answers.get("sleep", "7–8h"), 7)
                motiv   = motiv_map.get(answers.get("motivation", "😐 Mittel"), 3)

                base = st.session_state.score_history[-1]["score"]
                new_score = compute_score(study_h, abs_h, sleep_h, motiv, base)

                now = datetime.now()
                start_of_year = datetime(now.year, 1, 1)
                week_num = math.ceil(((now - start_of_year).days + start_of_year.weekday() + 1) / 7)
                st.session_state.score_history.append({"week": f"KW {week_num}", "score": new_score})
                st.session_state.current_score = new_score
                st.session_state.study_hours   = study_h
                st.session_state.checkin_done  = True
                st.rerun()


def page_exams():
    """Exam Planner: Prüfungen eingeben + Lernplan"""
    st.markdown("## 📅 Exam Planner")
    st.markdown('<p style="color:#888;font-size:14px;margin-top:-12px;margin-bottom:24px;">'
                'Trage deine Prüfungen ein und erhalte einen automatischen Lernplan.</p>',
                unsafe_allow_html=True)

    # ── Exam input ──────────────────────────────────────────────────────────────
    st.markdown('<div class="ss-card"><div class="ss-card-title">Meine Prüfungen</div>', unsafe_allow_html=True)

    exams = st.session_state.exams
    updated_exams = []

    for i, exam in enumerate(exams):
        cols = st.columns([3, 2, 1, 0.5])
        with cols[0]:
            name = st.text_input("Modul", value=exam["name"], key=f"exam_name_{i}", label_visibility="collapsed" if i > 0 else "visible")
        with cols[1]:
            d = st.date_input("Datum", value=exam["date"], key=f"exam_date_{i}",
                              label_visibility="collapsed" if i > 0 else "visible",
                              min_value=date.today())
        with cols[2]:
            ects = st.number_input("ECTS", value=exam["ects"], min_value=1, max_value=12,
                                   key=f"exam_ects_{i}", label_visibility="collapsed" if i > 0 else "visible")
        with cols[3]:
            remove = st.button("✕", key=f"remove_{i}")
        if not remove:
            updated_exams.append({"name": name, "date": d, "ects": ects})

    st.session_state.exams = updated_exams

    if st.button("+ Prüfung hinzufügen"):
        st.session_state.exams.append({"name": "", "date": date.today() + timedelta(days=30), "ects": 3})
        st.rerun()

    # Summary pills
    if updated_exams:
        pill_html = '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;padding-top:16px;border-top:1px solid #e0e0dc;">'
        for e in updated_exams:
            d_left = days_until(e["date"])
            uc = urgency_color(d_left)
            cls = f"pill-{uc}"
            pill_html += f'<span class="pill {cls}"><strong>{e["name"] or "?"}</strong> in {d_left}d</span>'
        pill_html += '</div>'
        st.markdown(pill_html, unsafe_allow_html=True)

    st.markdown("</div>", unsafe_allow_html=True)

    # ── Generate study plan ────────────────────────────────────────────────────
    if st.button("📊 Lernplan generieren", use_container_width=False):
        st.session_state["show_plan"] = True

    if st.session_state.get("show_plan") and updated_exams:
        st.markdown("---")
        st.markdown("### 📋 Dein Lernplan")

        today = date.today()
        # For each exam, calculate recommended daily study hours
        for exam in sorted(updated_exams, key=lambda x: x["date"]):
            if not exam["name"]: continue
            d_left = days_until(exam["date"])
            if d_left < 0:
                st.warning(f"**{exam['name']}** – Prüfung bereits vorbei.")
                continue

            hrs_needed = exam["ects"] * 8   # rough: 8h per ECTS
            daily_hrs  = round(hrs_needed / max(d_left, 1), 1)
            uc = urgency_color(d_left)
            badge_color = {"green": "#b5cc18", "orange": "#f59e0b", "red": "#f44336"}[uc]

            st.markdown(f"""
            <div class="ss-card">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                <div>
                  <span style="font-size:16px;font-weight:600;color:#1a1a1a;">{exam['name']}</span>
                  <span style="margin-left:10px;font-size:12px;color:#888;font-family:'DM Mono',monospace;">
                    {exam['date'].strftime('%d. %B %Y')}
                  </span>
                </div>
                <span style="background:{badge_color}22;color:{badge_color};border:1.5px solid {badge_color};
                             border-radius:999px;padding:4px 12px;font-size:12px;font-weight:600;">
                  {d_left} Tage
                </span>
              </div>
              <div style="display:flex;gap:20px;">
                <div class="metric-tile" style="flex:1;text-align:center;">
                  <div class="label">ECTS</div>
                  <div class="value">{exam['ects']}</div>
                </div>
                <div class="metric-tile" style="flex:1;text-align:center;">
                  <div class="label">Empf. Gesamtstunden</div>
                  <div class="value">{hrs_needed}h</div>
                </div>
                <div class="metric-tile" style="flex:1;text-align:center;">
                  <div class="label">Täglich</div>
                  <div class="value" style="color:{badge_color};">{daily_hrs}h</div>
                </div>
              </div>
            </div>
            """, unsafe_allow_html=True)

        # Week grid for the next 7 days
        st.markdown('<div class="ss-card"><div class="ss-card-title">Diese Woche</div>', unsafe_allow_html=True)

        cols = st.columns(7)
        days_de = ["Mo", "Di", "Mi", "Do", "Fr", "Sa", "So"]
        for i in range(7):
            day = today + timedelta(days=i)
            is_today = (day == today)
            is_weekend = day.weekday() >= 5
            # Distribute hours based on exams
            load = 0
            for e in updated_exams:
                d_left = days_until(e["date"])
                if 0 < d_left <= 30:
                    load += e["ects"] * (0.5 if is_weekend else 1.0) / max(d_left, 1)
            load = round(min(load * 6, 8), 1)

            bg   = "#eef3c2" if is_today else "#f2f2f0"
            bord = "1.5px solid #b5cc18" if is_today else "1.5px solid #e0e0dc"
            with cols[i]:
                st.markdown(f"""
                <div style="background:{bg};border:{bord};border-radius:12px;padding:14px 8px;
                            text-align:center;position:relative;">
                  {'<div style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#b5cc18;color:#1a1a1a;font-size:9px;font-weight:700;padding:2px 8px;border-radius:999px;white-space:nowrap;">HEUTE</div>' if is_today else ''}
                  <div style="font-size:10px;font-family:\'DM Mono\',monospace;letter-spacing:0.08em;color:{'#96ad00' if is_today else '#888'};margin-bottom:8px;text-transform:uppercase;">{days_de[day.weekday()]}</div>
                  <div style="font-size:26px;font-weight:700;font-family:\'DM Mono\',monospace;color:#1a1a1a;line-height:1;">{load}</div>
                  <div style="font-size:10px;color:#888;margin-top:2px;">Stunden</div>
                  <div style="font-size:12px;color:#888;margin-top:6px;">{day.strftime('%d.%m.')}</div>
                </div>
                """, unsafe_allow_html=True)
        st.markdown("</div>", unsafe_allow_html=True)


