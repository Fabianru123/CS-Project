# ── Helper ─────────────────────────────────────────────────────────────────────
def compute_score(study_h, absences, sleep_h, motivation, base=72):
    study_delta = (study_h - 5) * 2.5
    abs_delta   = -absences * 0.8
    sleep_delta = (sleep_h - 7) * 1.5
    motv_delta  = (motivation - 3) * 1.0
    raw = base + study_delta + abs_delta + sleep_delta + motv_delta
    return max(10, min(99, round(raw)))

def days_until(d: date) -> int:
    return (d - date.today()).days

def urgency_color(days):
    if days < 14: return "red"
    if days < 28: return "orange"
    return "green"

